// 方向 DIRECTION 定义  [3:0]
#define DIR_INVALID                0x00U    // 0000 Invalid (无效)
#define DIR_HOST_TO_BSS            0x01U    // 0001 Host → BSS (主机 -> 雷达BSS)
#define DIR_BSS_TO_HOST            0x02U    // 0010 BSS → Host (雷达BSS -> 主机)
#define DIR_HOST_TO_DSS            0x03U    // 0011 Host → DSS
#define DIR_DSS_TO_HOST            0x04U    // 0100 DSS → Host
#define DIR_HOST_TO_MASTER         0x05U    // 0101 Host → Master
#define DIR_MASTER_TO_HOST         0x06U    // 0110 Master → Host
#define DIR_BSS_TO_MASTER          0x07U    // 0111 BSS → Master
#define DIR_MASTER_TO_BSS          0x08U    // 1000 Master → BSS
#define DIR_BSS_TO_DSS             0x09U    // 1001 BSS → DSS
#define DIR_DSS_TO_BSS             0x0AU    // 1010 DSS → BSS
#define DIR_MASTER_TO_DSS          0x0BU    // 1011 Master → DSS
#define DIR_DSS_TO_MASTER          0x0CU    // 1100 DSS → Master
// 1101 (0x0D) 1110 (0x0E) 1111 (0x0F) 均为 RESERVED (保留)

// 消息类型定义（文档图2.5、表2.2）
#define MSGTYPE_COMMAND             0x00U         // 命令消息
#define MSGTYPE_RESPONSE_ACK        0x01U         // ACK响应
#define MSGTYPE_RESPONSE_NACK       0x02U         // NACK响应
#define MSGTYPE_ASYNC_EVENT         0x03U         // 异步事件

// 方向定义（文档表2.2）
#define DIRECTION_HOST_TO_BSS       0x01U         // 主机→BSS子系统
#define DIRECTION_HOST_TO_MASTER    0x05U         // 主机→Master子系统

// 构建OPCODE（真正的16位OPCODE）
#define MAKE_OPCODE(msgid)     (((msgid) << 6) | (MSGTYPE_COMMAND << 4) | DIR_HOST_TO_DEV)
#define MAKE_ACK_OPCODE(msgid) (((msgid) << 6) | (MSGTYPE_RESPONSE_ACK << 4) | DIR_BSS_TO_HOST)


