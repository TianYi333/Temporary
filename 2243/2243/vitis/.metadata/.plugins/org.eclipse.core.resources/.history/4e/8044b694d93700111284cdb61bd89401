// 协议宏定义（严格遵循文档）
#define PROTOCOL_SYNC_HOST_TO_RADAR  0x43211234UL  	// 主机→雷达同步字（文档表2.1）
#define PROTOCOL_HEADER_LEN         12U           	// MSGHDR长度（文档2.3.2）
#define PROTOCOL_MAX_DATA_LEN       240U          	// 最大数据长度（总长度≤252，文档9节）
 #define PROTOCOL_MAX_FRAME_LEN     252U  			// 一帧最大长度
#define PROTOCOL_CRC_LEN            4U            	// CRC-32（文档推荐，表2.7）
#define PROTOCOL_VERSION            0x01U         	// 协议版本（4位，文档表2.4）
#define PROTOCOL_SEQ_NUM_INIT       0x00U         	// 初始序列号

// 消息类型定义（文档图2.5、表2.2）
#define MSGTYPE_COMMAND             0x00U         // 命令消息
#define MSGTYPE_RESPONSE_ACK        0x01U         // ACK响应
#define MSGTYPE_RESPONSE_NACK       0x02U         // NACK响应
#define MSGTYPE_ASYNC_EVENT         0x03U         // 异步事件

// 方向定义（文档表2.2）
#define DIRECTION_HOST_TO_BSS       0x01U         // 主机→BSS子系统
#define DIRECTION_HOST_TO_MASTER    0x05U         // 主机→Master子系统

// 命令OPCODE映射（文档4.1节，关键消息ID）
#define OPCODE_AWR_RF_STATIC_CONF_SET_MSG  0x04U  // 静态配置设置
#define OPCODE_AWR_RF_DYNAMIC_CONF_SET_MSG 0x08U  // 动态配置设置
#define OPCODE_AWR_RF_FRAME_TRIG_MSG       0x0AU  // 帧触发
#define OPCODE_AWR_DEV_RFPOWERUP_MSG       0x200U // 设备上电
#define OPCODE_AWR_DEV_CONF_SET_MSG        0x202U // 设备配置设置

//自定义消息头
#define Custom_Message_Header 	0xBA01 //自定义消息头

// 协议结构体（小端模式）
// 消息头结构（文档图2.4）
typedef struct
{
    uint16_t opcode;        // 操作码（MSGID+MSGTYPE+DIRECTION）
    uint16_t msg_len;       // 消息总长度（含头+数据+CRC，不含SYNC）
    uint16_t flags;         // 控制标志
    uint16_t rem_chunks;    // 剩余分片数（不分片为0）
    uint16_t nsbc;          // 子块数量（单块为1）
    uint16_t chksum;        // 消息头校验和
} __attribute__((packed)) RadarMsgHeader_t;

// 数据子块结构（文档图2.9）
typedef struct
{
    uint16_t sblk_id;       // 子块ID（文档5节子块定义）
    uint16_t sblk_len;      // 子块长度（含ID+长度+数据）
    uint8_t  sblk_data[];   // 子块数据（变长）
} __attribute__((packed)) RadarSubBlock_t;


// 帧消息结构体（给队列使用）
typedef struct {
    uint8_t data[2 + 4 + PROTOCOL_MAX_FRAME_LEN];
    uint16_t len;
} AxiLiteFrame_t;


// 版本子块（响应）
typedef struct {
    uint8_t  type;       // 0=MSS,1=BSS,2=RF,3=DFP
    uint8_t  major;
    uint8_t  minor;
    uint8_t  patch;
    uint32_t build;
    char     date[12];   // "MM DD YYYY HH:MM"
} RadarVersion_t;

// 全局保存版本
extern RadarVersion_t g_radar_ver;


void PL_AXI_Lite_PS_function(void);
void PS_AXI_Lite_PL_function(void);
int MMWL_SendCmd(uint16_t cmd, const void* data, uint16_t len, uint16_t sblk_id);





