void PS_AXI_Lite_PL_function(void)/* PS端发送到PL端任务*/
{
	uint32_t Tx_Data;
	AxiLiteFrame_t msg={0};
	Tx_Data_0_last=Tx_Data_0;
	uint8_t custom_seq = 0x00;     // 芯片序号
    while(1)
    {
    	memset(&msg, 0, sizeof(AxiLiteFrame_t));
        if(xQueueReceive(PS_AXI_TO_PL_Queue, &msg, portMAX_DELAY))
        {
        	if(msg.data[0] == 0xBA && msg.data[1] == 0x01)
        	{
				uint16_t total_len  = msg.len;           // 整包有效数据总长度
				uint16_t data_offset = 0;                // 数据偏移
				uint16_t chunk_idx   = 0;                // 分片序号

				printf("===== 开始下发帧 | 总长度：%d 字节 | 自定义序号：%02X =====\n", total_len, custom_seq);

				// 第一步：先发【BA01头包】60字节
				uint8_t first_pkt[60] = {0};
				first_pkt[0] = 0xBA;
				first_pkt[1] = 0x01;
				first_pkt[2] = custom_seq;                          // 自定义序号
				first_pkt[3] = (total_len >> 8) & 0xFF;             // 总长度高字节
				first_pkt[4] = total_len & 0xFF;                    // 总长度低字节

				// 发送 BA01 头包（60字节）
				for(int i=0; i<15; i++)
				{
					int idx = i*4;
					Tx_Data  = (uint32_t)first_pkt[idx+0] << 24;
					Tx_Data |= (uint32_t)first_pkt[idx+1] << 16;
					Tx_Data |= (uint32_t)first_pkt[idx+2] << 8;
					Tx_Data |= (uint32_t)first_pkt[idx+3];

					PS_PL_AXI4_mWriteReg(AXI_CMD_BASE_ADDR, tx_reg_addrs[i+1], Tx_Data);
				}
				// 触发PL
				Tx_Data_0 = (Tx_Data_0 >= 0xFFFFFFFE) ? 1 : Tx_Data_0+1;
				PS_PL_AXI4_mWriteReg(AXI_CMD_BASE_ADDR, tx_reg_addrs[0], Tx_Data_0);
				vTaskDelay(1);
				printf("→ BA01头包下发完成\n");

				// 第二步：循环发送【BA02数据分片】每包60字节
				while(data_offset < total_len)
				{
					uint8_t data_pkt[60] = {0};
					uint16_t copy_len = total_len - data_offset;

					// 每包最多55字节有效数据
					if(copy_len > 55) copy_len = 55;

					// 组包：BA02 + 自定义序号 + 分片序号 + 55字节数据
					data_pkt[0] = 0xBA;
					data_pkt[1] = 0x02;
					data_pkt[2] = custom_seq;                          // 自定义序号
					data_pkt[3] = (chunk_idx >> 8) & 0xFF;            // 分片序号高字节
					data_pkt[4] = chunk_idx & 0xFF;                   // 分片序号低字节

					// 复制55字节有效数据到 pkt[5 ~ 59]
					memcpy(&data_pkt[5], &msg.data[data_offset], copy_len);

					// 发送这60字节
					for(int i=0; i<15; i++)
					{
						int idx = i*4;
						Tx_Data  = (uint32_t)data_pkt[idx+0] << 24;
						Tx_Data |= (uint32_t)data_pkt[idx+1] << 16;
						Tx_Data |= (uint32_t)data_pkt[idx+2] << 8;
						Tx_Data |= (uint32_t)data_pkt[idx+3];

						PS_PL_AXI4_mWriteReg(AXI_CMD_BASE_ADDR, tx_reg_addrs[i+1], Tx_Data);
					}

					// 触发PL
					Tx_Data_0 = (Tx_Data_0 >= 0xFFFFFFFE) ? 1 : Tx_Data_0+1;
					PS_PL_AXI4_mWriteReg(AXI_CMD_BASE_ADDR, tx_reg_addrs[0], Tx_Data_0);
					vTaskDelay(1);

					printf("→ BA02分片%d | 偏移:%d | 本次数据:%d字节\n", chunk_idx, data_offset, copy_len);

					data_offset += copy_len;
					chunk_idx++;
				}
				printf("===== 整包发送完成！共 %d 个分片 =====\n\n", chunk_idx);
        	}
        	else if(msg.data[0] == 0xBA && msg.data[1] == 0x05)
        	{

        	}
        	else if(msg.data[0] == 0xBB && msg.data[1] == 0x01)
        	{

        	}
        	else if(msg.data[0] == 0xCC && msg.data[1] == 0x01)
        	{

        	}
        }
    }
}


