// 全局序列号（每次发送自增，重传不变）
static uint8_t g_protocol_seq_num = PROTOCOL_SEQ_NUM_INIT;


// 工具函数（CRC32计算，文档表2.7）
static uint32_t crc32_calculate(const uint8_t* data, uint32_t len)
{
    const uint32_t crc_poly = 0xEDB88320UL; // CRC-32多项式（文档表2.7）
    uint32_t crc = 0xFFFFFFFFUL;

    for (uint32_t i = 0; i < len; i++)
    {
        crc ^= data[i];
        for (uint32_t j = 0; j < 8; j++)
        {
            crc = (crc >> 1) ^ ((crc & 0x01UL) ? crc_poly : 0UL);
        }
    }
    return ~crc;
}


// 消息头校验和计算（文档2.3.2）
static uint16_t msg_header_checksum(const RadarMsgHeader_t* header)
{
    const uint8_t* data = (const uint8_t*)header;  // 用 uint8_t 绝对安全
    uint32_t sum = 0UL;

    // 共 10 字节 = 5 个 uint16_t
    for (int i = 0; i < 10; i += 2)
    {
        // 手动组合 2 字节 → 16位（小端模式，和TI协议一致）
        uint16_t val = (uint16_t)data[i] | ((uint16_t)data[i+1] << 8);
        sum += val;

        if (sum > 0xFFFFUL)
        {
            sum = (sum & 0xFFFFUL) + 1UL;
        }
    }

    return (uint16_t)~sum; // 一补码
}


// 命令→OPCODE转换（映射文档消息ID）
static uint16_t cmd_to_opcode(uint8_t cmd)
{
    // OPCODE格式：[15:6]MSGID + [5:4]MSGTYPE + [3:0]DIRECTION（文档图2.5）
    return (cmd << 6) | (MSGTYPE_COMMAND << 4) | DIR_HOST_TO_BSS;
}


//  MMWL_SendCmd
int MMWL_SendCmd(uint16_t cmd, const void* data, uint16_t len, uint16_t sblk_id)
{
    // 入参检查
	// 数据为空但长度 > 0，非法
    if (data == NULL && len > 0) return -1;

    // 计算总长度
    // 子块总长度 = 子块头 + 用户数据
    const uint16_t subblk_len = sizeof(RadarSubBlock_t) + len; // 子块总长度
    // 整帧（除同步字外）总长度 = 头 + 子块 + CRC
    const uint16_t msg_total_len = PROTOCOL_HEADER_LEN + subblk_len + PROTOCOL_CRC_LEN;

    // 分片逻辑：如果整帧 >252，必须分片发送
    if (msg_total_len > PROTOCOL_MAX_FRAME_LEN)
    {
        // 每一片能携带的最大数据长度
		const uint16_t max_per_chunk = PROTOCOL_MAX_FRAME_LEN
										 - PROTOCOL_HEADER_LEN
										 - PROTOCOL_CRC_LEN
										 - sizeof(RadarSubBlock_t);
        uint16_t offset = 0;
        uint16_t remain = len;
        uint8_t  chunk_idx = 0;

        // 计算总分片数
        uint8_t total_chunks = (len + max_per_chunk - 1) / max_per_chunk;

        // 循环分片发送
        while (remain > 0)
        {
            uint16_t send_len = (remain > max_per_chunk) ? max_per_chunk : remain;

            AxiLiteFrame_t frameMsg;
            memset(&frameMsg, 0, sizeof(frameMsg));
            uint8_t *frame_ptr = frameMsg.data;

            // ===================== 在这里添加 2 字节自定义头 =====================
            *frame_ptr++ = (Custom_Message_Header >> 8) & 0xFF;  // 高字节 BA
            *frame_ptr++ = Custom_Message_Header & 0xFF;         // 低字节 01

            // 同步字
            *(uint32_t*)frame_ptr = PROTOCOL_SYNC_HOST_TO_RADAR;
            frame_ptr += 4;

            // 头
            RadarMsgHeader_t *header = (RadarMsgHeader_t*)frame_ptr;
            header->opcode = cmd_to_opcode(cmd);
            header->msg_len = PROTOCOL_HEADER_LEN + (sizeof(RadarSubBlock_t) + send_len) + PROTOCOL_CRC_LEN;
            header->rem_chunks = total_chunks - chunk_idx - 1; // 剩余片数（关键！）
            header->nsbc = 1;

            // flags
            uint16_t flags = 0U;
			flags |= (g_protocol_seq_num & 0x0FU) << 12;
			flags |= (0x01U) << 8;
			flags |= (PROTOCOL_VERSION & 0x0FU) << 4;
			flags |= (0x00U) << 2;
			flags |= (0x00U) << 0;
			header->flags = flags;
			header->chksum = msg_header_checksum(header);
			frame_ptr += PROTOCOL_HEADER_LEN;

            // 子块
            RadarSubBlock_t *sub = (RadarSubBlock_t*)frame_ptr;
            sub->sblk_id = sblk_id;
            sub->sblk_len = sizeof(RadarSubBlock_t) + send_len;
            memcpy(sub->sblk_data, (const uint8_t*)data + offset, send_len);
            frame_ptr += sub->sblk_len;

            // CRC（跳过自定义头+同步字）
            uint32_t crc = crc32_calculate(frameMsg.data + 2 + 4, PROTOCOL_HEADER_LEN + sub->sblk_len);
            *(uint32_t*)frame_ptr = crc;

            // 实际发送长度
            frameMsg.len = 4 + header->msg_len + 2;
            // 底层发送
            xQueueSend(PS_AXI_TO_PL_Queue, &frameMsg, portMAX_DELAY);

            // ===================== 分片帧调试打印=====================
            //uint32_t 类型 → 必须用 %08lX
            //uint16_t 类型 → 打印用 %04X
            //uint8_t  类型 → 打印用 %02X
            printf("=========================================\n");
            printf("TI 雷达协议【分片帧】发送成功\n");
            printf("分片序号  	: %d/%d\n" , chunk_idx + 1, total_chunks);
            printf("剩余分片  	: %d\n"    , header->rem_chunks);
            printf("同步字    	: %08lX\n", *(uint32_t*)frameMsg.data);
            printf("OPCODE 	: 0x%04X\n", header->opcode);
            printf("消息总长度	: %d 字节\n", header->msg_len);
            printf("Flags  	: 0x%04X\n", header->flags);
            printf("子块数量  	: %d\n"    , header->nsbc);
            printf("头部校验  	: 0x%04X\n", header->chksum);
            printf("CRC32 	: %08lX\n", crc);
            printf("=========================================\n\n");

            // 更新偏移
            offset += send_len;
            remain -= send_len;
            chunk_idx++;
        }

        g_protocol_seq_num = (g_protocol_seq_num + 1) & 0xF;
        return 0;
    }
    // 不需要分片
    // 分配帧缓冲区（SYNC+头+子块+CRC）
    // 总缓冲区 = 同步字(4) + 消息(头+数据+CRC)
    AxiLiteFrame_t frameMsg;
    // 清空缓冲区
    memset(&frameMsg, 0, sizeof(frameMsg));
    // 指针用于组帧
    uint8_t* frame_ptr = frameMsg.data;

    // 写入自定义2字节头 0xBA01
    *frame_ptr++ = (Custom_Message_Header >> 8) & 0xFF;
    *frame_ptr++ = Custom_Message_Header & 0xFF;

    // 小端模式写入 4 字节同步字 (文档 2.3.1)
    *(uint32_t*)frame_ptr = PROTOCOL_SYNC_HOST_TO_RADAR;
    frame_ptr += 4;// 指针后移 4 字节

    // 填充消息头（RadarMsgHeader_t）
    RadarMsgHeader_t* header = (RadarMsgHeader_t*)frame_ptr;
    // 操作码：命令字 → 设备协议 OPCODE
    header->opcode = cmd_to_opcode(cmd);          // 转换为TI官方OPCODE
    // 消息总长度（不含同步字）
    header->msg_len = msg_total_len;              // 消息总长度
    // 不分片，固定为 0
    header->rem_chunks = 0x0000U;                // 不分片
    // 单个子块，固定为 1
    header->nsbc = 0x0001U;                      // 1个子块

    // 组FLAGS（文档表2.4）
    uint16_t flags = 0U;
    flags |= (g_protocol_seq_num & 0x0FU) << 12; // [15:12]序列号 4 位
    flags |= (0x01U) << 8;                       // [9:8]CRC类型（00=16位，01=32位）
    flags |= (PROTOCOL_VERSION & 0x0FU) << 4;    // [7:4]协议版本
    flags |= (0x00U) << 2;                       // [3:2]ACK请求（00=需要ACK）
    flags |= (0x00U) << 0;                       // [1:0]重试标志（00=新消息）
    header->flags = flags;

    // 计算消息头校验和
    header->chksum = msg_header_checksum(header);
    // 指针移动到数据区
    frame_ptr += PROTOCOL_HEADER_LEN;

    // 组数据子块（文档图2.9）
    RadarSubBlock_t* subblk = (RadarSubBlock_t*)frame_ptr;
    subblk->sblk_id = sblk_id;                   // 子块ID：根据实际配置类型修改（示例：通道配置子块，文档5.2.1）
    subblk->sblk_len = subblk_len;               // 子块总长度
    // 子块数据，复制用户配置数据
    if (data != NULL && len > 0)
        memcpy(subblk->sblk_data, data, len);
    // 指针移动到 CRC 位置
    frame_ptr += subblk_len;

    // 计算并填写 CRC32（覆盖头+子块，文档2.3.4）
    uint32_t crc = crc32_calculate((uint8_t*)header, PROTOCOL_HEADER_LEN + subblk_len);
    *(uint32_t*)frame_ptr = crc;

    frameMsg.len = 4 + msg_total_len + 2;

    // 调用底层发送接口
    xQueueSend(PS_AXI_TO_PL_Queue, &frameMsg, portMAX_DELAY);

    // ===================== 调试打印 =====================
    printf("=========================================\n");
    printf("TI 雷达协议帧发送成功\n");
    printf("同步字    	: 0x%08lX\n", *(uint32_t*)frameMsg.data);  // 已修复
    printf("OPCODE  : 0x%04X\n", header->opcode);
    printf("消息总长度	: %d 字节\n", header->msg_len);
    printf("Flags  	: 0x%04X\n", header->flags);
    printf("子块数量	: %d\n"    , header->nsbc);
    printf("头部校验  	: 0x%04X\n", header->chksum);
    printf("CRC32  	: 0x%08lX\n", crc);
    printf("=========================================\n\n");

    // 序列号自增（重传时不变，需扩展重传逻辑）
    g_protocol_seq_num = (g_protocol_seq_num + 1) & 0x0FU;

    return 0;
}


// 传入：已经组好的、完整的 TI 雷达协议（无自定义头）
int MMWL_ParseVersionFromRxBuf_Complete(uint8_t *complete_ti_buf)
{
    uint8_t *p_proto = complete_ti_buf;

    // 同步字
    uint32_t sync = *(uint32_t *)p_proto;
    if (sync != PROTOCOL_SYNC_HOST_TO_RADAR)
    {
        printf("[解析] 同步字错误！\n");
        return -1;
    }

    // 消息头
    RadarMsgHeader_t *hdr = (RadarMsgHeader_t *)(p_proto + 4);
    uint16_t opcode = hdr->opcode;

    // 从 OPCODE 中提取 MSGID、MSGTYPE、DIRECTION
    uint16_t msg_id   = (opcode >> 6) & 0x3FF;   // 命令号
    uint8_t  msg_type = (opcode >> 4) & 0x03;    // 消息类型
    uint8_t  dir      = opcode & 0x0F;           // 方向

    // 定位子块
	uint8_t *p_sub = p_proto + 4 + PROTOCOL_HEADER_LEN;
	RadarSubBlock_t *sub = (RadarSubBlock_t *)p_sub;
	uint16_t sblk_id = sub->sblk_id;

    // 雷达响应必须满足：
    // 类型 = RESPONSE(01)
    // 方向 = DEV→HOST(0x02)
    if (msg_type != 0x01 || dir != 0x02)
    {
        printf("不是有效响应包\n");
        return -2;
    }

    // 版本查询响应：MSGID=0x11 + 子块ID=0x0220
    if (msg_id == 0x11 && sblk_id == 0x0220)
    {
        MMWL_FwVer_t *ver = (MMWL_FwVer_t *)sub->sblk_data;
        g_chip_version.maj = ver->maj;
        g_chip_version.min = ver->min;
        g_chip_version.pat = ver->pat;
        g_chip_version.bld = ver->bld;

        printf("=========================================\n");
        printf("版本解析成功：%d.%d.%d.%d\n",
               g_chip_version.maj, g_chip_version.min,
               g_chip_version.pat, g_chip_version.bld);
        printf("=========================================\n");

        xSemaphoreGive(g_version_sem);
    }
    else// 通用配置命令 ACK
    {
        printf("命令响应成功：MSGID=0x%02X\n", msg_id);
    }
   return 0;
}


