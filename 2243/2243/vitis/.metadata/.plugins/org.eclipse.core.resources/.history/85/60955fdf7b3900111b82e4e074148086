
#include "tcp_server.h"


/* thread spawned for each connection */
void tcp_recv_perf_traffic(void *p)
{
	char recv_buf[63]= "\0";
	int read_bytes;
	int sock = *((int *)p);
	u8 Lwip_recv_buf[60]={0};
	u8 Data_bytes = 0;

	while (1) {
		/* read a max of RECV_BUF_SIZE bytes from socket */
		if ((read_bytes = lwip_recvfrom(sock, recv_buf, 60,
						0, NULL, NULL)) < 0)
		{
			xil_printf("%s: error reading from socket %d, closing socket\r\n", __FUNCTION__, sock);
			break;
		}
		else
		{
			if (!strncmp(recv_buf, "quit", 4))
				break;
			memcpy(Lwip_recv_buf, recv_buf, read_bytes);
			if(Lwip_recv_buf[0] == 0xAA)//校验头
			{
				Data_bytes = Lwip_recv_buf[1];
				if(Lwip_recv_buf[Data_bytes+2] == 0xBB)//校验尾
				{
					xQueueSend(Lwip_Receive_Queue,Lwip_recv_buf,0);
				}
			}
			memset(Lwip_recv_buf, 0, read_bytes);
		}

		/* break if client closed connection */
		if (read_bytes == 0) {
			xil_printf("TCP close!\n\r");
			break;
		}
		memset(recv_buf, 0, sizeof(recv_buf));
	}
	/* close connection */
	close(sock);
	vTaskDelete(NULL);
}

/* thread spawned for each connection */
void TCP_send_perf_traffic(void *p)
{
	int write_bytes;
	int sock = *((int *)p);
	uint8_t Lwip_send_buf[60]={0};
	uint8_t send_buf[63]={0};

	while (1) {
		//改为portMAX_DELAY，队列无数据时，TCP 线程进入阻塞态，释放 CPU 给 LWIP 协议栈和 DMA 中断处理；队列有数据时立即唤醒发送，无任何延迟，不影响发送速率。
		if(xQueueReceive(Lwip_Send_Queue,Lwip_send_buf,portMAX_DELAY))/* 从队列接收消息成功 */
		{
			send_buf[0] = 0xAA;//消息尾
			memcpy(&send_buf[2], Lwip_send_buf, 60);
			if(Lwip_send_buf[0]==0xBA)
			{
				if(Lwip_send_buf[1]==0x01 || Lwip_send_buf[1]==0x02 || Lwip_send_buf[1]==0x03 || Lwip_send_buf[1]==0x05)
				{
					send_buf[1] = 0x05;//数据总长度5字节
					send_buf[7] = 0xBB;//消息尾
					if ((write_bytes = write(sock, send_buf, 8)) < 0)
					{
						xil_printf("Closing socket %d\r\n", sock);
						break;
					}
				}
				else if(Lwip_send_buf[1]==0x04)
				{
					send_buf[1] = 0x3C;//数据总长度60字节
					send_buf[62] = 0xBB;//消息尾
					if ((write_bytes = write(sock, Lwip_send_buf, 63)) < 0)
					{
						xil_printf("Closing socket %d\r\n", sock);
						break;
					}
				}
			}
			else if(Lwip_send_buf[0]==0xAB)
			{
				send_buf[1] = 0x05;//数据总长度5字节
				send_buf[7] = 0xBB;//消息尾
				if ((write_bytes = write(sock, send_buf, 8)) < 0)
				{
					xil_printf("Closing socket %d\r\n", sock);
					break;
				}
			}
			else if(Lwip_send_buf[0]==0xBB)
			{
				send_buf[1] = 0x05;//数据总长度5字节
				send_buf[7] = 0xBB;//消息尾
				if ((write_bytes = write(sock, send_buf, 8)) < 0)
				{
					xil_printf("Closing socket %d\r\n", sock);
					break;
				}
			}
			else if(Lwip_send_buf[0]==0xCC)
			{
				send_buf[1] = 0x0A;//数据总长度10字节
				send_buf[12] = 0xBB;//消息尾
				if ((write_bytes = write(sock, send_buf, 13)) < 0)
				{
					xil_printf("Closing socket %d\r\n", sock);
					break;
				}
			}
		}
	}
	close(sock);
	vTaskDelete(NULL);
}

void start_application(void)
{
	int sock, new_sd;
#if LWIP_IPV6==1
	struct sockaddr_in6 address, remote;
#else
	struct sockaddr_in address, remote;
#endif /* LWIP_IPV6 */
	int size;

	/* set up address to connect to */
        memset(&address, 0, sizeof(address));
#if LWIP_IPV6==1
	if ((sock = lwip_socket(AF_INET6, SOCK_STREAM, 0)) < 0) {
		xil_printf("TCP server: Error creating Socket\r\n");
		return;
	}
	address.sin6_family = AF_INET6;
	address.sin6_port = htons(TCP_CONN_PORT);
	address.sin6_len = sizeof(address);
#else
	if ((sock = lwip_socket(AF_INET, SOCK_STREAM, 0)) < 0) {
		xil_printf("TCP server: Error creating Socket\r\n");
		return;
	}
	address.sin_family = AF_INET;
	address.sin_port = htons(TCP_CONN_PORT);
	address.sin_addr.s_addr = INADDR_ANY;
#endif /* LWIP_IPV6 */

	if (bind(sock, (struct sockaddr *)&address, sizeof (address)) < 0) {
		xil_printf("TCP server: Unable to bind to port %d\r\n",
				TCP_CONN_PORT);
		close(sock);
		return;
	}

	if (listen(sock, 1) < 0) {
		xil_printf("TCP server: tcp_listen failed\r\n");
		close(sock);
		return;
	}

	size = sizeof(remote);

	while (1) {
		if ((new_sd = accept(sock, (struct sockaddr *)&remote,
						(socklen_t *)&size)) > 0)
		{
			sys_thread_new("TCP_recv_perf thread",
				tcp_recv_perf_traffic, (void*)&new_sd,
				TCP_SERVER_THREAD_STACKSIZE,
				DEFAULT_THREAD_PRIO);
			sys_thread_new("TCP_send_perf thread",
				TCP_send_perf_traffic, (void*)&new_sd,
				TCP_SERVER_THREAD_STACKSIZE,
				DEFAULT_THREAD_PRIO+1);
		}
	}
}


void Lwip_Receive_function(void)/* 以太网数据接收处理任务 */
{
	uint8_t Lwip_Receive_buf[63]={0};
	uint8_t Axi_send_buf[60]={0};
	uint8_t timeout_count = 0;//超时计数
	while(1)
	{
		if(xQueueReceive(Lwip_Receive_Queue,Lwip_Receive_buf,1000) == pdFAIL)
		{
			timeout_count++;
			if(timeout_count>=30)
			{
				timeout_count=0;
				//strcpy(Lwip_Send_buf, "NO data");
				//xQueueSend(Lwip_Send_Queue,Lwip_Send_buf,0);
			}
			continue;
		}
		else
		{
			timeout_count = 0;
    		u8 Data_bytes = Axi_send_buf[0];
    		if(Data_bytes >= 60)
    		{
    			Data_bytes = 60;
    		}
    		memcpy(Axi_send_buf,&Lwip_Receive_buf[2],Data_bytes);//只复制数据部分
    		if(Axi_send_buf[0] == 0xBA && Axi_send_buf[1] == 0x01)
    		{
        		memset(Lwip_Receive_buf, 0, 60);
    		    memset(Axi_send_buf, 0, 60);
    		}
    		else if(Axi_send_buf[0] == 0xBA && Axi_send_buf[1] == 0x02)
    		{
        		memset(Lwip_Receive_buf, 0, 60);
    		    memset(Axi_send_buf, 0, 60);
    		}
    		else
    		{
    		    xQueueSend(PS_AXI_TO_PL_Queue,Axi_send_buf,200);
        		memset(Lwip_Receive_buf, 0, 60);
    		    memset(Axi_send_buf, 0, 60);
    		}
		}
	}
}
